{
  "name": "medical-imaging-platform",
  "version": "1.0.0",
  "description": "医疗影像云端远程诊断平台",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "wasm"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:wasm": "npm run build --workspace=wasm",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm run build:wasm && npm run build:backend && npm run build:frontend"
  },
  "keywords": [
    "DICOM",
    "WebAssembly",
    "Vue3",
    "Node.js",
    "AWS S3",
    "医疗影像"
  ],
  "author": "",
  "license": "MIT"
}
